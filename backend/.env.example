# LLM API 配置
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL_NAME=deepseek-ai/DeepSeek-V3
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# 叙事配置
NARRATOR_TEMPERATURE=0.5

# 可配置参数 (v0.6.0+)
# QUALITY_PASS=48        # 质量门禁及格线
# TENSION_DANGER=0.3      # 张力:危险权重
# TENSION_EMOTION=0.25    # 张力:情绪权重
# PARALLEL_LINES=5        # 最大并行线数
# BEATS_PER_POV=3         # POV 切换频率
# BATCH_NARRATE=3         # 叙事批次大小
